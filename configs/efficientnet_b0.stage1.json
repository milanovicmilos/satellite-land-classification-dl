{
  "experiment_name": "efficientnet-b0-stage1-frozen",
  "dataset_root": "data/EuroSAT",
  "split": {
    "train_ratio": 0.7,
    "validation_ratio": 0.15,
    "test_ratio": 0.15,
    "seed": 42,
    "stratified": true
  },
  "training": {
    "epochs": 1,
    "batch_size": 16,
    "early_stopping_patience": 1
  },
  "model": {
    "name": "efficientnet_b0",
    "options": {
      "use_pretrained": true,
      "freeze_backbone": true
    }
  }
}
